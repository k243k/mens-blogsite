# =============================================================================
# メンズエステ体験レビューサイト 環境変数テンプレート
# 実値は .env.local に置く（.env.local は git 無視）。
# =============================================================================

# --- 公開サイトURL（メタ・sitemap・canonical 用） ---
NEXT_PUBLIC_SITE_URL=https://jiisan-estet.com

# -----------------------------------------------------------------------------
# Supabase（クライアント / ビルド時）
#   ⚠️ ここに置けるのは anon key だけ。RLS で無料公開情報のみ取得可能にする。
#   ⚠️ service_role key は絶対にここへ置かない（クライアント・静的成果物に漏れる）。
#      service_role key は Supabase Edge Functions の Secrets でのみ保持する。
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# -----------------------------------------------------------------------------
# 以下は Supabase Edge Functions 側の Secrets として設定する（このファイルには置かない）。
# 参考のため変数名のみ記載:
#   SUPABASE_SERVICE_ROLE_KEY   ... 有料本文配信・購入登録（Edge Functions のみ）
#   STRIPE_SECRET_KEY           ... Stripe Checkout 発行（Edge Functions のみ）
#   STRIPE_WEBHOOK_SECRET       ... Stripe Webhook 署名検証（Edge Functions のみ）
#   GITHUB_DISPATCH_TOKEN       ... 公開時の workflow_dispatch 起動（Edge Functions のみ）
# -----------------------------------------------------------------------------
